# ==========================================
# HMS Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git!
# ==========================================

# --- MySQL ---
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Keycloak ---
KC_DB_USER=
KC_DB_PASSWORD=
KC_DB_ROOT_PASSWORD=
KC_ADMIN=
KC_ADMIN_PASSWORD=
KEYCLOAK_ISSUER_URI=http://localhost:9090/realms/hms
KEYCLOAK_JWK_SET_URI=http://localhost:9090/realms/hms/protocol/openid-connect/certs

# --- Mail ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Server ---
SERVER_PORT=8080
